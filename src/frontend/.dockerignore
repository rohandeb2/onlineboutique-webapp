# ==========================================
# 1. Go Specific (Critical)
# ==========================================
# Exclude local compiled binaries and object files
bin/
obj/
# Exclude vendor directory to ensure fresh builds from go.mod
vendor/
# Tests are for CI, not for the production image
*_test.go

# ==========================================
# 2. Version Control & Global Ignores
# ==========================================
.git
.gitignore
.dockerignore
.editorconfig
*.md
LICENSE

# ==========================================
# 3. Environment & Security (CRITICAL)
# ==========================================
# Prevent leaking local secrets into ECR
.env
.env.*
*.pem
*.key

# ==========================================
# 4. IDE & OS Junk
# ==========================================
.vscode/
.idea/
.DS_Store
Thumbs.db

# ==========================================
# 5. Infrastructure & Build Artifacts
# ==========================================
.terraform/
*.tfstate*
kubernetes-files/
# Exclude the proto generation script after it runs in CI
genproto.sh
